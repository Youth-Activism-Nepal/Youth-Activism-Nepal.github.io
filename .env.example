## Copy to `.env.local` for local development.
## Use one of the options below.

# Preferred: point directly to the local FastAPI backend
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_BASE_URL=https://data.youthactivismnepal.org.np

# Alternative: use the selector in `src/config/api.ts`
# NEXT_PUBLIC_API_ENV=local
